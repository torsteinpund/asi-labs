{
  "name": "Python (CUDA)",
  "image": "nvcr.io/nvidia/cuda:12.6.3-cudnn-devel-ubuntu24.04",
  // Feature configurations
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "configureZshAsDefaultShell": true
    }
  },
  // These commands run after the container is created.
  "postCreateCommand": {
    // Install uv
    "uv": "curl -LsSf https://astral.sh/uv/install.sh | sh"
    // Other installation commands can be added here
  },
  // These commands run each time the container is attached.
  "postAttachCommand": {
    // Synchronize uv environment (if uv.lock exists)
    "uv-sync": "test -f uv.lock && uv sync --locked --extra cuda || echo 'No uv.lock file found, skipping uv sync.'"
    // Other attach-time commands can be added here
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff",
        "ms-toolsai.jupyter"
      ]
    }
  },
  "runArgs": [
    "--gpus",
    "all"
  ]
}